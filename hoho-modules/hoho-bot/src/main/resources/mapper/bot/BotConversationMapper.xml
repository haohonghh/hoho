<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hoho.bot.mapper.BotConversationMapper">

    <resultMap type="BotConversation" id="BotConversationResult">
        <id property="id" column="id"/>
        <result property="conversationId" column="conversation_id"/>
        <result property="title" column="title"/>
        <result property="lastMessage" column="last_message"/>
        <result property="messageCount" column="message_count"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectConversationVo">
        select id, conversation_id, title, last_message, message_count, create_time, update_time
        from bot_conversation
    </sql>

    <select id="selectByConversationId" parameterType="String" resultMap="BotConversationResult">
        <include refid="selectConversationVo"/>
        where conversation_id = #{conversationId}
        limit 1
    </select>

    <select id="selectConversationList" resultMap="BotConversationResult">
        <include refid="selectConversationVo"/>
        order by update_time desc, id desc
    </select>

    <insert id="insertConversation" parameterType="BotConversation" useGeneratedKeys="true" keyProperty="id">
        insert into bot_conversation(conversation_id, title, last_message, message_count, create_time, update_time)
        values(#{conversationId}, #{title}, #{lastMessage}, 0, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    </insert>

    <update id="updateConversationSummary" parameterType="BotConversation">
        update bot_conversation
        set last_message = #{lastMessage},
            message_count = message_count + 1,
            update_time = CURRENT_TIMESTAMP
        where conversation_id = #{conversationId}
    </update>

</mapper>
