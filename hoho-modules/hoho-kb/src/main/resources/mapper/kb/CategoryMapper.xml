<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hoho.kb.mapper.CategoryMapper">

    <resultMap type="Category" id="CategoryResult">
        <id property="id" column="id"/>
        <result property="parentId" column="parent_id"/>
        <result property="name" column="name"/>
        <result property="sort" column="sort"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <insert id="insert" parameterType="Category" useGeneratedKeys="true" keyProperty="id">
        insert into kb_category(parent_id, name, sort)
        values(#{parentId}, #{name}, #{sort})
    </insert>

    <select id="list" resultMap="CategoryResult">
        select id, parent_id, name, sort, status, create_time, update_time
        from kb_category
        order by sort asc, id asc
    </select>

</mapper>
