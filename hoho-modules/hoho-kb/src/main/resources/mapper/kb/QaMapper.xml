<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.hoho.kb.mapper.QaMapper">

    <resultMap type="Qa" id="QaResult">
        <id property="id" column="id"/>
        <result property="categoryId" column="category_id"/>
        <result property="question" column="question"/>
        <result property="answer" column="answer"/>
        <result property="similarQuestions" column="similar_questions"/>
        <result property="status" column="status"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="selectQaVo">
        select id, category_id, question, answer, similar_questions, status, create_time, update_time
        from kb_qa
    </sql>

    <insert id="insert" parameterType="Qa" useGeneratedKeys="true" keyProperty="id">
        insert into kb_qa(category_id, question, answer, similar_questions)
        values(#{categoryId}, #{question}, #{answer}, #{similarQuestions})
    </insert>

    <update id="update" parameterType="Qa">
        update kb_qa
        set category_id = #{categoryId},
            question = #{question},
            answer = #{answer},
            similar_questions = #{similarQuestions},
            status = 'draft',
            update_time = CURRENT_TIMESTAMP
        where id = #{id}
    </update>

    <select id="selectById" parameterType="Long" resultMap="QaResult">
        <include refid="selectQaVo"/>
        where id = #{id}
    </select>

    <select id="list" resultMap="QaResult">
        <include refid="selectQaVo"/>
        order by id desc
    </select>

    <update id="updateStatus">
        update kb_qa
        set status = #{status},
            update_time = CURRENT_TIMESTAMP
        where id = #{id}
    </update>

</mapper>
